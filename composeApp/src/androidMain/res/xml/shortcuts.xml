<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="search"
        android:shortcutShortLabel="@string/shortcut_search"
        android:shortcutLongLabel="@string/shortcut_search">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="githubstore://search"
            android:targetPackage="zed.rainxch.githubstore"
            android:targetClass="zed.rainxch.githubstore.MainActivity" />
    </shortcut>

    <shortcut
        android:shortcutId="library"
        android:shortcutShortLabel="@string/shortcut_library"
        android:shortcutLongLabel="@string/shortcut_library">
